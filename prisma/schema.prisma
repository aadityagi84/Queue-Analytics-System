generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Transaction {
  id          String   @id
  userId      String
  amount      Float
  currency    String
  timestamp   DateTime
  processedAt DateTime @default(now())
  status      String   @default("PROCESSED")
}